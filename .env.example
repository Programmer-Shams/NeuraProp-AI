AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
SQS_INBOUND_QUEUE_URL=http://localhost:4566/000000000000/neuraprop-inbound
SQS_OUTBOUND_QUEUE_URL=http://localhost:4566/000000000000/neuraprop-outbound
S3_BUCKET_NAME=neuraprop-storage

# LLM Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Email
