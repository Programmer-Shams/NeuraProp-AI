# =============================================================================
# NeuraProp AI — Environment Configuration
# Copy to .env and fill in your values: cp .env.example .env
# =============================================================================

# --- App ---
APP_ENV=development              # development | staging | production
LOG_LEVEL=DEBUG                  # DEBUG | INFO | WARNING | ERROR
API_BASE_URL=http://localhost:8000
DASHBOARD_URL=http://localhost:3000

# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL=postgresql+asyncpg://neuraprop:neuraprop@localhost:5432/neuraprop
DATABASE_URL_SYNC=postgresql://neuraprop:neuraprop@localhost:5432/neuraprop
DB_PASSWORD=neuraprop            # Change in production!

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- AWS (LocalStack for development) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test           # Real credentials in production
AWS_SECRET_ACCESS_KEY=test       # Real credentials in production
AWS_ENDPOINT_URL=http://localhost:4566  # Remove in production (uses real AWS)
SQS_INBOUND_QUEUE_URL=http://localhost:4566/000000000000/neuraprop-inbound
SQS_OUTBOUND_QUEUE_URL=http://localhost:4566/000000000000/neuraprop-outbound
S3_BUCKET_NAME=neuraprop-storage

# --- LLM Providers ---
ANTHROPIC_API_KEY=               # Required: get from https://console.anthropic.com
OPENAI_API_KEY=                  # Optional: fallback provider

# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=  # Get from https://dashboard.clerk.com
CLERK_SECRET_KEY=                   # Get from https://dashboard.clerk.com

# --- Encryption ---
# Generate with: make gen-encryption-key
# Or: python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=                  # Required for PII encryption at rest

# --- Email ---
SENDGRID_API_KEY=                # For outbound email delivery

# --- Discord (optional, for Discord channel adapter) ---
# DISCORD_BOT_TOKEN=             # Per-firm tokens configured in admin
